# Server
PORT=3000
NODE_ENV=development

# CORS — set to your actual domain in production (e.g. https://yoursite.com)
CORS_ORIGIN=http://localhost:3000

# Database
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=teletext_scores_2

# Test database (used by integration tests only)
TEST_DB_DATABASE=teletext_scores_2_test

# FPL Draft
FPL_LEAGUE_ID=44363

# Football API (api-sports.io direct) — server-side only, never sent to client
# Get your key from: https://dashboard.api-football.com/
FOOTBALL_API_KEY=your_api_sports_key_here

# OpenFPL Scout AI (RapidAPI) — server-side only, powers AI predictions
# Get your key from: https://rapidapi.com/elcaiseri/api/openfpl-scout-ai
# Leave unset to disable AI predictions entirely.
OPENFPL_API_KEY=your_rapidapi_key_here

# First gameweek to generate AI predictions for.
# Set to 32 for the 2025-26 season (mid-season introduction).
# Remove or set to 1 for future seasons to enable from GW1.
PREDICTIONS_START_GW=32
