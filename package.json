{
  "name": "teletext-scores-2",
  "version": "2.0.0",
  "description": "Teletext-style football scores app with FPL Draft integration",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "migrate": "node server/db/migrate.js",
    "cron": "node server/jobs/cron.js",
    "load:one-time": "node server/jobs/one-time-load.js",
    "load:weekly-complete": "node server/jobs/weekly-complete.js",
    "load:weekly-start": "node server/jobs/weekly-start.js",
    "load:frequent": "node server/jobs/frequent-load.js",
    "health": "node server/jobs/health-check.js",
    "clear:fpl": "node server/jobs/clear-fpl-data.js",
    "test": "node --test 'tests/**/*.test.js'",
    "test:unit": "node --test 'tests/unit/**/*.test.js'",
    "test:integration": "node --test 'tests/integration/**/*.test.js'"
  },
  "dependencies": {
    "axios": "^1.6.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "",
  "license": "ISC"
}
